# Backend Environment Variables (example)

# Supabase (Service role key should NEVER be exposed to the frontend)
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=coloque_sua_service_role_key_aqui
SUPABASE_ANON_KEY=coloque_sua_anon_key_aqui

# OpenAI (usado para redigir diagnósticos dos tickets — opcional, tickets funcionam sem)
OPENAI_API_KEY=sk-...

# Server
PORT=3001
NODE_ENV=development
# Permitir mutações sem autenticação no ambiente local (apenas para smoke tests)
# ALLOW_UNAUTHENTICATED_MUTATIONS=true
