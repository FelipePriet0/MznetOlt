# Database
POSTGRES_URL=postgresql://user:password@localhost:5432/smartolt_dev
DATABASE_URL=${POSTGRES_URL}

# Application
NEXT_PUBLIC_APP_NAME=smartolt
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase (Futuro)
SUPABASE_URL=https://project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OLT Driver
OLT_DRIVER_MODE=mock
# OLT_DRIVER_VENDOR=huawei|ciena|nokia
# OLT_DRIVER_HOST=192.168.1.100
# OLT_DRIVER_PORT=23

# JWT
JWT_SECRET=your-secret-key-here-min-32-chars
JWT_EXPIRATION=24h

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Workers
REDIS_URL=redis://localhost:6379
WORKER_QUEUE_ENABLED=true

# Optional: Email (para notificações)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
