{
  "name": "@smartolt/backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register src/index.ts",
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "check:supabase": "node scripts/check_supabase.mjs",
    "db:tables": "node scripts/list_tables.mjs",
    "db:verify": "node scripts/check_tables.mjs",
    "seed:unconfigured": "node scripts/seed_unconfigured_onus.mjs",
    "seed:onus-unconfigured": "node scripts/seed_onus_unconfigured.mjs"
  },
  "bin": {},
  "dependencies": {
    "openai": "^4.53.0",
    "@supabase/supabase-js": "^2.99.0",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0"
  }
}